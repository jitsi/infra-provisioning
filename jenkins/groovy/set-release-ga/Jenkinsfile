import groovy.json.JsonOutput

def governance

def setReleaseGA(environment) {
    def setReleaseResult = sh(
        script: """#!/bin/bash
ENVIRONMENT=${environment} scripts/set-release-ga.sh ubuntu
"""
    )
}

def versioningManagerSetGA(environment, release_number) {
    sh(
        script: """#!/bin/bash
export VERSIONING_ACTION=SET_RELEASE_GA
export VERSIONING_RELEASE="${release_number}"
ENVIRONMENT=${environment} scripts/versioning-manager.sh
"""
    )
}

def addGAPoolsToScheduler(environment, release_number) {
    sh(
        script: """#!/bin/bash
. clouds/all.sh
if [ -z "\$ORACLE_REGIONS" ]; then
    echo "## addLiveLocalPoolsToScheduler failed to load ORACLE_REGIONS"
else
    for REGION in \$ORACLE_REGIONS; do
        JVB_GROUPS="\$(DEBUG=true ALL_RELEASES=true ORACLE_REGION=\${REGION} scripts/custom-autoscaler-list-groups.sh)"
        if [[ \${#JVB_GROUPS} != 0 ]]; then
            echo "## found jvb scaling groups for \${REGION}: \${JVB_GROUPS}"
        fi
        for GROUP in \$JVB_GROUPS; do
            if [[ "\$GROUP" =~ "JVB" ]] && [[ "\$GROUP" =~ "${release_number}" ]] && ([[ "\$GROUP" =~ "-local-" ]] || [[ "\$GROUP" =~ "-global-" ]]); then
                echo "## adding to scheduler: \${GROUP}"
                ENABLE_SCHEDULER=true ORACLE_REGION=\${REGION} GROUP_NAME=\${GROUP} TYPE=JVB scripts/custom-autoscaler-update-scaling-activities.sh
            else
                echo "## removing from scheduler: \${GROUP}"
                ENABLE_SCHEDULER=false ORACLE_REGION=\${REGION} GROUP_NAME=\${GROUP} TYPE=JVB scripts/custom-autoscaler-update-scaling-activities.sh
            fi
        done
    done
fi
"""
    )
}

pipeline {
    agent any
    options {
        ansiColor('xterm')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '10'))
    }
    stages {
        stage ("setup") {
            steps {
                script {
                    // load utility function
                    def rootDir = pwd()
                    utils = load "${rootDir}/jenkins/groovy/Utils.groovy"
                    // checkout repos
                    utils.SetupRepos(env.VIDEO_INFRA_BRANCH)

                    // setup OCI credentials
                    utils.SetupOCI()

                    sh 'mkdir -p test-results'
                }
            }
        }  
        stage ("load flags") {
            steps {
                script {
                    dir("infra-provisioning") {
                        useReleaseBackends = utils.GetEnvironmentVar(env.ENVIRONMENT, "USE_RELEASE_BACKENDS")
                        echo useReleaseBackends
                        recordReleases = utils.GetAnsibleVar(env.ENVIRONMENT, "release_recording_enabled")
                        echo recordReleases
                    }
                }
            }
        }
        stage ("set release GA on haproxies then in consul") {
            steps {
                script {
                    echo 'setting release live'
                    lock("haproxy-state-${env.ENVIRONMENT}") {
                        dir("infra-provisioning") {
                            withCredentials([
                                file(credentialsId: 'oci-jenkins-config', variable: 'OCI_CLI_CONFIG_FILE'),
                                file(credentialsId: 'oci-jenkins-pem', variable: 'OCI_CLI_KEY_FILE'),
                                string(credentialsId: 'jenkins-aws-secret', variable: 'AWS_SECRET_ACCESS_KEY'),
                                string(credentialsId: 'jenkins-aws-id', variable: 'AWS_ACCESS_KEY_ID')
                            ]) {
                                sshagent (credentials: ['ssh-ubuntu']) {
                                    setReleaseGA(env.ENVIRONMENT)
                                }
                            }
                        }
                    }
                }
            }
        }
        stage ("set release GA in versioning manager") {
            when {
                expression { useReleaseBackends == 'true' }
            }
            steps {
                script {
                    dir("infra-provisioning") {
                        withCredentials([
                            string(credentialsId: 'asap-jwt-kid-dev', variable: 'ASAP_JWT_KID_DEV'),
                            string(credentialsId: 'asap-jwt-kid-prod', variable: 'ASAP_JWT_KID_PROD'),
                            file(credentialsId: 'asap-jwt-key-dev', variable: 'ASAP_JWT_KEY_DEV'),
                            file(credentialsId: 'asap-jwt-key-prod', variable: 'ASAP_JWT_KEY_PROD')
                        ]) {
                            versioningManagerSetGA(env.ENVIRONMENT, env.RELEASE_NUMBER)
                        }
                    }
                }
            }
        }
        stage ("enable release JVB pools for use with autoscaler") {
            steps {
                script {
                    dir("infra-provisioning") {
                        withCredentials([
                            string(credentialsId: 'asap-jwt-kid-dev', variable: 'ASAP_JWT_KID_DEV'),
                            string(credentialsId: 'asap-jwt-kid-prod', variable: 'ASAP_JWT_KID_PROD'),
                            file(credentialsId: 'asap-jwt-key-dev', variable: 'ASAP_JWT_KEY_DEV'),
                            file(credentialsId: 'asap-jwt-key-prod', variable: 'ASAP_JWT_KEY_PROD')
                        ]) {
                            addGAPoolsToScheduler(env.ENVIRONMENT, env.RELEASE_NUMBER)
                        }
                    }
                }
            }
        }
        // Notify governance that the release is now GA (post-enable). Runs after the
        // promotion has succeeded and fails open — a governance error must never
        // block or fail a release that is already live. progress {audience: GA}
        // marks general availability.
        stage ("notify governance (post-enable)") {
            steps {
                script {
                    dir("infra-provisioning") {
                        try {
                            // Recover the release details stored at release-core time
                            // (keyed by release number) so post-enable references the same
                            // RP and the real per-service component versions as the release.
                            def details = [:]
                            try {
                                def raw = sh(returnStdout: true, script: """#!/bin/bash
ENVIRONMENT=${env.ENVIRONMENT} RELEASE_NUMBER=${env.RELEASE_NUMBER} scripts/consul-get-release-details.sh
""").trim()
                                if (raw) { details = readJSON(text: raw) }
                            } catch (lookupErr) {
                                echo "WARNING: could not read release details from consul: ${lookupErr.message}"
                            }

                            // RP: explicit param wins, else the value stored at release time.
                            def rpTicket = (params.RP_TICKET?.trim()) ?: (details.rp ?: '')
                            if (rpTicket && !(rpTicket ==~ /RP-\d+/)) {
                                echo "Ignoring non-RP value for release ${env.RELEASE_NUMBER}: '${rpTicket}'"
                                rpTicket = ''
                            }
                            // Components: stored per-service versions, else a single core fallback.
                            def components = (details.components instanceof List && details.components) \
                                ? details.components \
                                : [[name: 'core', type: 'vm', version: env.RELEASE_NUMBER]]
                            echo "Post-enable RP ticket: ${rpTicket ?: '(none)'}, components: ${components}"

                            governance = utils.LoadGovernanceHooks()
                            governance.init([
                                serviceName:  'core',
                                version:      env.RELEASE_NUMBER,
                                artifactType: 'vm',
                                environment:  env.ENVIRONMENT,
                                // Standard governance job parameters (see
                                // the governance provider's JOB_PARAMETERS.md).
                                // Undefined params resolve to null -> init applies its defaults.
                                rpTicket:     rpTicket,
                                useStaging:   params.GOVERNANCE_STAGING,
                                disabled:     (params.GOVERNANCE_ENABLED == false),
                                verbose:      params.GOVERNANCE_VERBOSE,
                            ])
                            // effectiveAt defaults to now (the GA moment) inside the hook.
                            // releaseId/name/environment/components form the release
                            // envelope /gate/release validates; reuse the original
                            // release's id so the enable ties back to that release.
                            governance.postEnable([
                                releaseId:  details.releaseId ?: "${env.RELEASE_NUMBER}_core",
                                name:       "Core release ${env.RELEASE_NUMBER}",
                                key:        'core',
                                label:      "Core release ${env.RELEASE_NUMBER} (${env.ENVIRONMENT})",
                                components: components,
                                progress:   [audience: 'GA'],
                            ])

                            // Record the GA moment back into the stored details (best effort).
                            if (details) {
                                try {
                                    details.gaAt = sh(returnStdout: true, script: 'date -u +"%Y-%m-%dT%H:%M:%SZ"').trim()
                                    if (rpTicket) { details.rp = rpTicket }
                                    writeFile file: 'release-details.json', text: JsonOutput.toJson(details)
                                    withEnv(["ENVIRONMENT=${env.ENVIRONMENT}", "RELEASE_NUMBER=${env.RELEASE_NUMBER}", "DETAILS_FILE=release-details.json"]) {
                                        sh 'scripts/consul-set-release-details.sh'
                                    }
                                } catch (saveErr) {
                                    echo "WARNING: could not update release details with gaAt: ${saveErr.message}"
                                }
                            }
                        } catch (err) {
                            echo "WARNING: governance post-enable notification failed: ${err.message} — continuing, release is already GA"
                        }
                    }
                }
            }
        }
        stage ("record release in docs-private") {
            when {
                expression { recordReleases == 'true' }
            }
            steps {
                script {
                    build job: 'record-release',parameters: [
                            [$class: 'StringParameterValue', name: 'ENVIRONMENT', value: env.ENVIRONMENT],
                            [$class: 'StringParameterValue', name: 'RELEASE_ID', value: env.RELEASE_NUMBER],
                            [$class: 'StringParameterValue', name: 'RELEASE_TYPE', value: 'core'],
                            [$class: 'StringParameterValue', name: 'RELEASE_ACTION', value: 'promote'],
                            [$class: 'StringParameterValue', name: 'VIDEO_INFRA_BRANCH', value: env.VIDEO_INFRA_BRANCH]
                        ]
                }
            }        
        }
     }     
     post {
        always {
            cleanWs()
        }
        failure {
            slackSend color: "danger", message: "${env.JOB_NAME} - build ${env.BUILD_NUMBER} failed to set release ${env.RELEASE_NUMBER} as GA in ${env.ENVIRONMENT}"
        }
    }
}
