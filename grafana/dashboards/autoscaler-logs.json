          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "{task=\"autoscaler\", region=~\"${region:regex}\"} | json | level=~\"${level:regex}\" |= `$search` | line_format `{{ if .message }}{{ .message }}{{ if .group }} [group={{ .group }}]{{ end }}{{ if .groupName }} [group={{ .groupName }}]{{ end }}{{ if .rid }} [rid={{ .rid }}]{{ end }}{{ else if .m }}HTTP {{ .m }} {{ .u }} {{ .s }} {{ .d }}ms{{ if .rid }} [rid={{ .rid }}]{{ end }}{{ else }}{{ __line__ }}{{ end }}`",
          "queryType": "range",
          "refId": "B",
          "hide": false
        }
