          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({service=\"jitsi-autoscaler\"} | json | line_format \"{{.message}}\" | json | __error__=\"\" | level=~\"${level:regex}\" |= `$search` [$__auto]))",
