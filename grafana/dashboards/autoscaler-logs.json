          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({task=\"autoscaler\", region=~\"${region:regex}\"} | json | level=~\"${level:regex}\" |= `$search` [$__auto]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "refId": "B",
          "hide": false
